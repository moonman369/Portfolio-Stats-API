# Copy to `.env` and fill in real values. Never commit the real `.env`.

# ---- Server ----
# Standardize on 8000 (matches code default and Docker EXPOSE/port mapping).
PORT=8000

# ---- MongoDB (Atlas) ----
# Atlas is required: the MoonMind RAG subsystem uses $vectorSearch, which a
# self-hosted mongo container does not support out of the box.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>

# ---- GitHub stats refresh ----
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
REFRESH_PROFILE=your-github-username
REFRESH_SECRET=change-me-long-random-string

# ---- LeetCode ----
LEETCODE_USERNAME=your-leetcode-username

# ---- OpenAI / MoonMind (RAG subsystem) ----
# Base only — code appends the "/v1/..." path itself, so do NOT include /v1 here.
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
MOONMIND_PASSWORD=change-me
MOONMIND_EMBEDDING_MODEL=text-embedding-3-small
MOONMIND_RESPONSE_MODEL=gpt-4o-mini
MOONMIND_INTENT_MODEL=gpt-4o-mini
MOONMIND_DB_NAME=portfolio-stats-api
MOONMIND_VECTOR_COLLECTION=moonmindVectorMemory
MOONMIND_METADATA_COLLECTION=moonmindMetadataIndex
# NOTE: two files read two different var names for the same setting — set BOTH
# to the same value until the code is unified:
#   src/moonmind/retrieval/vectorSearch.js -> MOONMIND_VECTOR_INDEX
#   config/vectorConfig.js                 -> MOONMIND_VECTOR_INDEX_NAME
MOONMIND_VECTOR_INDEX=moonmind_vector_index
MOONMIND_VECTOR_INDEX_NAME=moonmind_vector_index
MOONMIND_VECTOR_FIELD=embedding
MOONMIND_SUMMARY_MIN_SENTENCES=3
MOONMIND_SUMMARY_MAX_SENTENCES=6
MOONMIND_ENFORCE_SUMMARY_SENTENCE_RANGE=true
# Defaults to ON unless set to the literal string "false" — keep it off in prod.
MOONMIND_DEBUG=false
