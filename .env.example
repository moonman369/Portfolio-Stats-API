# Copy to `.env` and fill in real values. Never commit the real `.env`.

# ---- Server ----
# Standardize on 8000 (matches code default and Docker EXPOSE/port mapping).
PORT=8000

# ---- MongoDB (Atlas) ----
# Atlas is required: the MoonMind RAG subsystem uses $vectorSearch with an
# autoEmbed vector index, which only Atlas provides.
# Canonical name; the legacy MONGO_URI is still honored as a fallback.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>
# Database that holds all collections (legacy fallback: MOONMIND_DB_NAME).
MONGODB_DB_NAME=portfolio-stats-api

# ---- Vector search (Atlas autoEmbed) — all REQUIRED, startup fails if unset ----
# Collection backed by the autoEmbed vector index; documents are stored WITHOUT
# an embedding field (legacy fallback: MOONMIND_VECTOR_COLLECTION).
VECTOR_COLLECTION_NAME=documents_v2
# Name of the autoEmbed Atlas Vector Search index on that collection
# (legacy fallbacks: MOONMIND_VECTOR_INDEX / MOONMIND_VECTOR_INDEX_NAME).
VECTOR_INDEX_NAME=moonmind_autoembed_index
# Text field(s) the index auto-embeds. Comma-separated: retrieval runs one
# $vectorSearch per field (single `path` each) and merges by best score.
VECTOR_TEXT_FIELD_PATH=content_full,summary_for_embedding,title
# autoEmbed model configured on the index; passed as the optional `model`
# option in $vectorSearch and surfaced in logs.
EMBEDDING_MODEL_NAME=voyage-4

# ---- GitHub stats refresh ----
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
REFRESH_PROFILE=your-github-username
REFRESH_SECRET=change-me-long-random-string

# ---- LeetCode ----
LEETCODE_USERNAME=your-leetcode-username

# ---- OpenAI / MoonMind (chat completions only — embeddings are Atlas-side) ----
# Base only — code appends the "/v1/..." path itself, so do NOT include /v1 here.
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
MOONMIND_PASSWORD=change-me
MOONMIND_RESPONSE_MODEL=gpt-4o-mini
MOONMIND_INTENT_MODEL=gpt-4o-mini
MOONMIND_METADATA_COLLECTION=moonmindMetadataIndex
MOONMIND_SUMMARY_MIN_SENTENCES=3
MOONMIND_SUMMARY_MAX_SENTENCES=6
MOONMIND_ENFORCE_SUMMARY_SENTENCE_RANGE=true

# ---- Retrieval tuning (all optional; safe defaults shown) ----
# ANN candidates scanned before the vector limit. Higher = better recall
# (legacy fallback: MOONMIND_VECTOR_NUM_CANDIDATES).
VECTOR_NUM_CANDIDATES=150
# Default $vectorSearch result limit per retrieval arm.
VECTOR_SEARCH_LIMIT=10
# Reciprocal Rank Fusion constant (standard default 60).
MOONMIND_RRF_K=60
# Minimum Atlas cosine score ((1+cos)/2, 0..1) a doc must reach to survive
# ranking. 0 = disabled. Recalibrate with scripts/eval/retrievalEval.js after
# the voyage-4 migration — thresholds tuned for text-embedding-3-small do NOT
# carry over.
MOONMIND_MIN_SEMANTIC_SCORE=0
# Second-stage LLM reranker over the top fused candidates (adds one LLM call).
MOONMIND_RERANK_ENABLED=false
MOONMIND_RERANK_CANDIDATES=20
# MOONMIND_RERANK_MODEL=gpt-4o-mini
# Query decomposition / multi-query fan-out for multi-part prompts (adds LLM
# calls: one to split + intent+retrieval per sub-query).
MOONMIND_DECOMPOSE_ENABLED=false
MOONMIND_DECOMPOSE_MAX_SUBQUERIES=3
# MOONMIND_DECOMPOSE_MODEL=gpt-4o-mini
# Verbose MoonMind logging (intent -> retrieval steps -> ranking -> response).
# Emits the retrieval-mechanism step logs to stdout / `docker compose logs`.
# Enabled unless set to the literal string "false"; set to "false" to silence.
MOONMIND_DEBUG=true
