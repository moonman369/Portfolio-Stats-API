# Copy to `.env` and fill in real values. Never commit the real `.env`.

# ---- Server ----
# Standardize on 8000 (matches code default and Docker EXPOSE/port mapping).
PORT=8000

# ---- MongoDB (Atlas) ----
# Atlas is required: the MoonMind RAG subsystem uses $vectorSearch, which a
# self-hosted mongo container does not support out of the box.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>

# ---- GitHub stats refresh ----
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
REFRESH_PROFILE=your-github-username
REFRESH_SECRET=change-me-long-random-string

# ---- LeetCode ----
LEETCODE_USERNAME=your-leetcode-username

# ---- Mongo collections (MoonMind RAG subsystem) ----
# These no longer fall back to the old MOONMIND_* names. Any MOONMIND_VECTOR_*
# or MOONMIND_DB_NAME left in your .env is now inert and can be deleted.
MONGO_DB_NAME=portfolio-stats-api
# Must be the collection the Atlas vector index below is built on.
MONGO_VECTOR_COLLECTION=moonmind_documents_v3
MONGO_METADATA_COLLECTION=moonmindMetadataIndex
MONGO_VECTOR_INDEX=vector_index
MONGO_VECTOR_FIELD=embedding

# ---- Gemini embeddings ----
# Base only — the code appends "/v1beta/models/<model>:embedContent".
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=AIza-xxxxxxxxxxxxxxxxxxxx
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
# MUST equal `numDimensions` on the Atlas vector index, or every write produces a
# vector the index cannot match. The live `vector_index` is 768.
GEMINI_EMBEDDING_DIMENSIONS=768
# Retry/backoff for Gemini 429s and transient 5xx. Honors `Retry-After`.
GEMINI_MAX_RETRIES=5
GEMINI_RETRY_BASE_MS=500
GEMINI_MAX_BACKOFF_MS=20000
GEMINI_TIMEOUT_MS=30000
# Character budget for the embedded text (model limit is 8192 tokens). The tail
# of content_full is truncated first; title, tags and summary are always kept.
GEMINI_MAX_INPUT_CHARS=28000

# ---- OpenAI / MoonMind (chat completions only) ----
# OpenAI still powers intent extraction, response generation, the LLM reranker
# and query decomposition. It no longer generates embeddings.
# Base only — code appends the "/v1/..." path itself, so do NOT include /v1 here.
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
MOONMIND_PASSWORD=change-me
MOONMIND_RESPONSE_MODEL=gpt-4o-mini
MOONMIND_INTENT_MODEL=gpt-4o-mini
MOONMIND_SUMMARY_MIN_SENTENCES=3
MOONMIND_SUMMARY_MAX_SENTENCES=6
MOONMIND_ENFORCE_SUMMARY_SENTENCE_RANGE=true

# ---- Retrieval tuning (all optional; safe defaults shown) ----
# ANN candidates scanned before the vector limit. Higher = better recall.
MOONMIND_VECTOR_NUM_CANDIDATES=150
# Reciprocal Rank Fusion constant (standard default 60).
MOONMIND_RRF_K=60
# Minimum Atlas cosine score ((1+cos)/2, 0..1) a doc must reach to survive
# ranking. 0 = disabled. Any previously tuned value is invalid after the Gemini
# migration — score distributions differ per embedding model. Recalibrate with
# scripts/eval/retrievalEval.js before raising this above 0.
MOONMIND_MIN_SEMANTIC_SCORE=0
# Second-stage LLM reranker over the top fused candidates (adds one LLM call).
MOONMIND_RERANK_ENABLED=false
MOONMIND_RERANK_CANDIDATES=20
# MOONMIND_RERANK_MODEL=gpt-4o-mini
# Query decomposition / multi-query fan-out for multi-part prompts (adds LLM
# calls: one to split + intent+retrieval per sub-query).
MOONMIND_DECOMPOSE_ENABLED=false
MOONMIND_DECOMPOSE_MAX_SUBQUERIES=3
# MOONMIND_DECOMPOSE_MODEL=gpt-4o-mini
# Verbose MoonMind logging (intent -> retrieval steps -> ranking -> response).
# Emits the retrieval-mechanism step logs to stdout / `docker compose logs`.
# Enabled unless set to the literal string "false"; set to "false" to silence.
MOONMIND_DEBUG=true
